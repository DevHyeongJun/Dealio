generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum SendStatus {
  PENDING
  SUCCESS
  FAIL
}

enum ProductCategory {
  DEVELOPMENT
  DESIGN
  MAINTENANCE
  PRINTING
}

enum Currency {
  KRW
  USD
}

enum UserRole {
  ADMIN
  USER
}

enum QuotationAction {
  CREATE
  UPDATE
  STATUS_CHANGE
  SEND
  DELETE
}

enum ContractAction {
  CREATE
  UPDATE
  PAYMENT_STATUS_CHANGE
  DELETE
}

enum ContractType {
  OUTSOURCING // 외주 (우리가 발주 → 돈을 보냄)
  SALES       // 수주 (우리가 수주 → 돈을 받음)
}

enum ContractPaymentStatus {
  UNPAID  // 미정산
  PARTIAL // 부분 정산
  PAID    // 정산 완료
}

enum ExpenseCategory {
  MEAL          // 식비
  TRANSPORT     // 교통비
  MATERIAL      // 자재비
  OUTSOURCING   // 외주비
  ENTERTAINMENT // 접대비
  COMMUNICATION // 통신비
  OFFICE        // 사무용품
  OTHER         // 기타
}

enum PaymentMethod {
  CARD     // 카드
  CASH     // 현금
  TRANSFER // 계좌이체
  OTHER
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?
  name         String
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  /// 사용자가 소속된 그룹사/관계사 (null = 미배정)
  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId    String?
  /// 명함 이미지 파일 경로 (fileStorage 기준 상대 경로)
  businessCardPath String?
  /// 명함 원본 파일명 (다운로드 시 표시용)
  businessCardName String?
  /// 직책
  jobTitle     String?
  /// 휴대폰
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdQuotations Quotation[]        @relation("QuotationCreatedBy")
  updatedQuotations Quotation[]        @relation("QuotationUpdatedBy")
  histories         QuotationHistory[]
  sendLogs          QuotationSendLog[]
  createdContracts  Contract[]         @relation("ContractCreatedBy")
  updatedContracts  Contract[]         @relation("ContractUpdatedBy")
  contractHistories ContractHistory[]
  expenses          Expense[]          @relation("ExpenseCreatedBy")
  accessLogs        AccessLog[]
  attachments       Attachment[]

  @@index([isActive])
  @@index([companyId])
}

/// 다양한 엔티티(계약, 견적서, 경비 등)에 첨부되는 파일을 한 곳에서 관리.
/// 실제 파일은 FILE_STORAGE/ 디렉토리에 저장되며, 이 테이블은 메타정보만 보관.
enum AttachmentEntity {
  CONTRACT
  QUOTATION
  EXPENSE
  CUSTOMER
  USER
}

model Attachment {
  id             String           @id @default(cuid())
  entityType     AttachmentEntity
  entityId       String
  filename       String           // 사용자가 업로드한 원본 파일명
  storedFilename String           // FILE_STORAGE 안의 실제 저장명
  mimetype       String
  size           Int              // 바이트
  uploadedBy     User?            @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedById   String?
  createdAt      DateTime         @default(now())

  @@index([entityType, entityId])
  @@index([uploadedById])
  @@index([createdAt])
}

/// 그룹사 / 관계사 — 각 사용자가 소속된 회사를 분류한다.
/// (Settings 의 "회사 정보" 는 견적서 발행 주체이고, 이건 별개 마스터)
model Company {
  id        String   @id @default(cuid())
  name      String
  /// 메모/설명 (선택)
  memo      String?
  isActive  Boolean  @default(true)
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([isActive])
}

/// IP 접속 허용 규칙. CIDR 표기 지원 (예: 192.168.0.0/24) 또는 단일 IP.
model AccessRule {
  id        String   @id @default(cuid())
  cidr      String   /// IPv4 CIDR 또는 단일 IP (예: "192.168.0.0/24", "203.0.113.5")
  label     String?  /// 사무실, 본사망 등 메모
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

/// 사용자가 접근한 메뉴/페이지 경로 추적용 로그.
model AccessLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  path      String
  label     String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([path])
}

model Quotation {
  id              String             @id @default(cuid())
  quotationNumber String             @unique
  title           String?
  customer        Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId      String?
  customerName    String
  customerEmail   String?
  customerPhone   String?
  customerAddress String?
  issueDate       DateTime           @default(now())
  validUntil      DateTime?
  status          QuotationStatus    @default(DRAFT)
  notes           String?
  totalAmount     Decimal            @default(0) @db.Decimal(14, 2)
  vatIncluded     Boolean            @default(true)
  items           QuotationItem[]
  sendLogs        QuotationSendLog[]
  histories       QuotationHistory[]
  contracts       Contract[]
  createdBy       User?              @relation("QuotationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById     String?
  updatedBy       User?              @relation("QuotationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedById     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([customerName])
  @@index([createdById])
  @@index([updatedById])
}

model QuotationSendLog {
  id          String     @id @default(cuid())
  quotation   Quotation  @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId      String?
  recipient   String
  cc          String?
  subject     String
  body        String
  status      SendStatus @default(PENDING)
  error       String?
  messageId   String?
  sentAt      DateTime   @default(now())

  @@index([quotationId])
  @@index([sentAt])
  @@index([userId])
}

model QuotationHistory {
  id          String          @id @default(cuid())
  quotation   Quotation       @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId      String?
  action      QuotationAction
  summary     String
  details     Json?
  createdAt   DateTime        @default(now())

  @@index([quotationId])
  @@index([userId])
  @@index([createdAt])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId   String?
  name        String
  description String?
  quantity    Int       @default(1)
  unitPrice   Decimal   @default(0) @db.Decimal(14, 2)
  amount      Decimal   @default(0) @db.Decimal(14, 2)
  sortOrder   Int       @default(0)

  @@index([quotationId])
  @@index([productId])
}

model Customer {
  id        String     @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  /// 사업자등록번호 (예: 123-45-67890)
  businessNumber  String?
  /// 대표자명
  representative  String?
  /// 사업지 주소 (사업자등록증상 주소)
  businessAddress String?
  /// 업태 (예: 서비스업)
  businessSector  String?
  /// 업종 / 종목 (예: 소프트웨어 개발)
  businessItem    String?
  memo      String?
  isActive  Boolean    @default(true)
  contracts Contract[]
  quotations Quotation[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([name])
  @@index([isActive])
}

model Contract {
  id               String                @id @default(cuid())
  contractNumber   String                @unique
  title            String
  type             ContractType
  counterpartyName String
  customer         Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId       String?
  quotation        Quotation?            @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  quotationId      String?
  amount           Decimal               @default(0) @db.Decimal(14, 2)
  /// 계약금액에 부가세가 포함되어 있는지. true → amount 가 합계, false → amount 는 공급가액.
  vatIncluded      Boolean               @default(true)
  paidAmount       Decimal               @default(0) @db.Decimal(14, 2)
  paymentStatus    ContractPaymentStatus @default(UNPAID)
  startDate        DateTime?
  endDate          DateTime?
  notes            String?
  createdBy        User?                 @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById      String?
  updatedBy        User?                 @relation("ContractUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedById      String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  histories        ContractHistory[]
  expenses         Expense[]

  @@index([type])
  @@index([paymentStatus])
  @@index([counterpartyName])
  @@index([customerId])
  @@index([quotationId])
  @@index([createdById])
}

model Expense {
  id            String          @id @default(cuid())
  expenseDate   DateTime        @default(now())
  category      ExpenseCategory @default(OTHER)
  description   String
  amount        Decimal         @db.Decimal(14, 2)
  paymentMethod PaymentMethod   @default(CARD)
  vendor        String?
  notes         String?
  contract      Contract?       @relation(fields: [contractId], references: [id], onDelete: SetNull)
  contractId    String?
  createdBy     User?           @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([expenseDate])
  @@index([contractId])
  @@index([category])
  @@index([createdById])
}

model ContractHistory {
  id         String         @id @default(cuid())
  contract   Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId String
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String?
  action     ContractAction
  summary    String
  details    Json?
  createdAt  DateTime       @default(now())

  @@index([contractId])
  @@index([userId])
  @@index([createdAt])
}

model Product {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  description    String?
  category       ProductCategory @default(DEVELOPMENT)
  unit           String          @default("EA")
  currency       Currency        @default(KRW)
  unitPrice      Decimal         @default(0) @db.Decimal(14, 2)
  isActive       Boolean         @default(true)
  usageCount     Int             @default(0)
  quotationItems QuotationItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([name])
  @@index([category])
  @@index([isActive])
  @@index([usageCount])
}


model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
